# Environment variables required for a notarized Developer ID release build.
# Copy this file to .env.release (git-ignored), fill in your values, then:
#
#   source .env.release && npm run build:electron:release
#
# Never commit .env.release — it contains secrets.

# ---------------------------------------------------------------------------
# Code signing — export your Developer ID Application cert from Keychain as
# a .p12 file, then either point to it or base64-encode it for CI:
#   base64 -i DeveloperID.p12 | pbcopy   (paste result below)
# ---------------------------------------------------------------------------
CSC_LINK=                        # /path/to/DeveloperID.p12  OR  base64-encoded .p12
CSC_KEY_PASSWORD=                # password you chose when exporting the .p12

# ---------------------------------------------------------------------------
# Notarization — generate an app-specific password at appleid.apple.com
# (Sign In → App-Specific Passwords).  Team ID is on developer.apple.com/account.
# ---------------------------------------------------------------------------
APPLE_ID=                        # e.g. you@example.com
APPLE_APP_SPECIFIC_PASSWORD=     # e.g. abcd-efgh-ijkl-mnop
APPLE_TEAM_ID=                   # 10-char string, e.g. ABC1234DEF
