<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet — load hosted DayGlance frontend (or remove if bundling locally) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Calendar -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Focus mode: Do Not Disturb control (requires user to grant DND access in system settings) -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- File access (Obsidian vault) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- Microphone — for voice-to-task input via WebView getUserMedia -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Health Connect — runtime permissions (required on Android 14+ where HC is built in) -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />

    <!-- Health Connect — queries block for devices running Health Connect as a standalone app -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:name=".DayGlanceApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DayGlance"
        android:usesCleartextTraffic="false">

        <!-- Main activity — WebView shell -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:windowSoftInputMode="adjustNothing"
            android:launchMode="singleTop"
            android:theme="@style/Theme.DayGlance.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Launcher shortcut: long-press app icon → "Voice Input" -->
            <intent-filter>
                <action android:name="com.dayglance.app.ACTION_VOICE_INPUT" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- Launcher shortcut: long-press app icon → "Inbox Task" -->
            <intent-filter>
                <action android:name="com.dayglance.app.ACTION_ADD_INBOX_TASK" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- Launcher shortcut: long-press app icon → "Scheduled Task" -->
            <intent-filter>
                <action android:name="com.dayglance.app.ACTION_ADD_TASK" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- Share sheet: other apps can share plain text / URLs to dayGLANCE -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- Health Connect: required so the system can show our permission rationale.
             Without this alias the PermissionController dialog will not launch. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- Settings activity -->
        <activity
            android:name=".settings.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Home screen widget: full agenda -->
        <receiver
            android:name=".widget.DayGlanceWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.dayglance.app.widget.ACTION_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- Home screen widget: Up Next (next scheduled task detail) -->
        <receiver
            android:name=".widget.UpNextWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.dayglance.app.widget.UPNEXT_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_upnext_info" />
        </receiver>

        <!-- Home screen widget: Goal (pinned goal card + child projects) -->
        <receiver
            android:name=".widget.GoalWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.dayglance.app.widget.GOAL_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_goal_info" />
        </receiver>

        <activity
            android:name=".widget.GoalWidgetConfigureActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Home screen widget: Project (pinned project card + tasks) -->
        <receiver
            android:name=".widget.ProjectWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.dayglance.app.widget.PROJECT_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_project_info" />
        </receiver>

        <activity
            android:name=".widget.ProjectWidgetConfigureActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!--
          RemoteViewsService that backs the scrollable ListView inside the widget.
          Must be exported=true so the launcher process can bind to it, but the
          binding is gated by the BIND_REMOTEVIEWS permission (held only by the system).
        -->
        <service
            android:name=".widget.DayGlanceWidgetListService"
            android:exported="true"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <!-- Alarm broadcast receiver for scheduled reminders -->
        <receiver
            android:name=".notifications.ReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Notification action button receiver (Snooze, Mark Complete) -->
        <receiver
            android:name=".notifications.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.dayglance.app.ACTION_SNOOZE" />
                <action android:name="com.dayglance.app.ACTION_COMPLETE" />
            </intent-filter>
        </receiver>

        <!-- AlarmManager-driven receiver that keeps the Up Next notification updated
             even when the WebView is suspended in the background. -->
        <receiver
            android:name=".notifications.UpNextNotificationUpdater"
            android:exported="false">
            <intent-filter>
                <action android:name="com.dayglance.app.notification.UP_NEXT_TICK" />
            </intent-filter>
        </receiver>

        <!-- FileProvider: used by NativeBridge.shareFile() to expose cache-dir JSON
             backup files to the system share sheet without WRITE_EXTERNAL_STORAGE. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
