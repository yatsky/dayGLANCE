<?xml version="1.0" encoding="utf-8"?>
<!--
  Project widget layout — shows a pinned project with task list.

  Structure:
    FrameLayout (root)
    └── LinearLayout (vertical)
        ├── Header: "PROJECT" brand label · refresh
        ├── Hairline divider
        ├── Project content (layout_project_content):
        │     Goal label chip (gone when standalone)
        │     Project header: colored bar | title
        │     Threshold progress bars (red/amber/green) · stats label
        │     Tasks divider (gone when no tasks)
        │     Task rows × 6 (each gone when unused)
        └── Empty / not-configured state (layout_project_empty)

  Progress bar coloring matches the three-bar pattern from widget_item_goal.xml:
    red (#ef4444) < 40%, amber (#f59e0b) 40–79%, green (#22c55e) ≥ 80%.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/project_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <!-- ── Header ────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROJECT"
                android:textColor="@color/widget_brand"
                android:textStyle="bold"
                android:textSize="11sp"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="" />

            <ImageView
                android:id="@+id/btn_project_widget_refresh"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_widget_refresh"
                android:padding="5dp"
                android:contentDescription="Refresh" />

        </LinearLayout>

        <!-- Hairline divider -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/widget_divider"
            android:layout_marginBottom="6dp"
            android:text="" />

        <!-- ── Project content ────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_project_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Parent goal chip (hidden when standalone) -->
            <TextView
                android:id="@+id/tv_pw_goal_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:text=""
                android:textColor="@color/widget_committed_text"
                android:textSize="10sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/widget_committed_pill"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Project card: colored left bar + vertical details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/project_widget_color_bar"
                    android:layout_width="3dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:background="#3b82f6"
                    android:text="" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Project title + status row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_pw_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Project title"
                            android:textColor="@color/widget_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- "Done" badge when 100% complete -->
                        <TextView
                            android:id="@+id/tv_pw_done_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="DONE"
                            android:textColor="#22c55e"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.06"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Progress bar row + stats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <!-- Red — < 40% -->
                        <ProgressBar
                            android:id="@+id/pb_pw_red"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#ef4444"
                            android:progressBackgroundTint="#33ef4444"
                            android:layout_marginEnd="6dp" />

                        <!-- Amber — 40–79% -->
                        <ProgressBar
                            android:id="@+id/pb_pw_amber"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#f59e0b"
                            android:progressBackgroundTint="#33f59e0b"
                            android:layout_marginEnd="6dp"
                            android:visibility="gone" />

                        <!-- Green — ≥ 80% -->
                        <ProgressBar
                            android:id="@+id/pb_pw_green"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#22c55e"
                            android:progressBackgroundTint="#3322c55e"
                            android:layout_marginEnd="6dp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_pw_stats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/widget_text_secondary"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Tasks divider -->
            <TextView
                android:id="@+id/tv_pw_tasks_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/widget_divider"
                android:layout_marginBottom="3dp"
                android:text=""
                android:visibility="gone" />

            <!-- Task row 1 -->
            <LinearLayout
                android:id="@+id/row_wt1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone">
                <TextView android:id="@+id/tv_wt1_check"
                    android:layout_width="16dp" android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp" android:text="○"
                    android:textSize="11sp" android:textColor="@color/widget_text_secondary" />
                <TextView android:id="@+id/tv_wt1_title"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text=""
                    android:textSize="12sp" android:textColor="@color/widget_text_primary"
                    android:maxLines="1" android:ellipsize="end" />
            </LinearLayout>

            <!-- Task row 2 -->
            <LinearLayout
                android:id="@+id/row_wt2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone">
                <TextView android:id="@+id/tv_wt2_check"
                    android:layout_width="16dp" android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp" android:text="○"
                    android:textSize="11sp" android:textColor="@color/widget_text_secondary" />
                <TextView android:id="@+id/tv_wt2_title"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text=""
                    android:textSize="12sp" android:textColor="@color/widget_text_primary"
                    android:maxLines="1" android:ellipsize="end" />
            </LinearLayout>

            <!-- Task row 3 -->
            <LinearLayout
                android:id="@+id/row_wt3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone">
                <TextView android:id="@+id/tv_wt3_check"
                    android:layout_width="16dp" android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp" android:text="○"
                    android:textSize="11sp" android:textColor="@color/widget_text_secondary" />
                <TextView android:id="@+id/tv_wt3_title"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text=""
                    android:textSize="12sp" android:textColor="@color/widget_text_primary"
                    android:maxLines="1" android:ellipsize="end" />
            </LinearLayout>

            <!-- Task row 4 -->
            <LinearLayout
                android:id="@+id/row_wt4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone">
                <TextView android:id="@+id/tv_wt4_check"
                    android:layout_width="16dp" android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp" android:text="○"
                    android:textSize="11sp" android:textColor="@color/widget_text_secondary" />
                <TextView android:id="@+id/tv_wt4_title"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text=""
                    android:textSize="12sp" android:textColor="@color/widget_text_primary"
                    android:maxLines="1" android:ellipsize="end" />
            </LinearLayout>

            <!-- Task row 5 -->
            <LinearLayout
                android:id="@+id/row_wt5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone">
                <TextView android:id="@+id/tv_wt5_check"
                    android:layout_width="16dp" android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp" android:text="○"
                    android:textSize="11sp" android:textColor="@color/widget_text_secondary" />
                <TextView android:id="@+id/tv_wt5_title"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text=""
                    android:textSize="12sp" android:textColor="@color/widget_text_primary"
                    android:maxLines="1" android:ellipsize="end" />
            </LinearLayout>

            <!-- Task row 6 -->
            <LinearLayout
                android:id="@+id/row_wt6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone">
                <TextView android:id="@+id/tv_wt6_check"
                    android:layout_width="16dp" android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp" android:text="○"
                    android:textSize="11sp" android:textColor="@color/widget_text_secondary" />
                <TextView android:id="@+id/tv_wt6_title"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text=""
                    android:textSize="12sp" android:textColor="@color/widget_text_primary"
                    android:maxLines="1" android:ellipsize="end" />
            </LinearLayout>

            <!-- Overflow: "+N more tasks" -->
            <TextView
                android:id="@+id/tv_pw_more_tasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:paddingStart="21dp"
                android:paddingTop="2dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── Empty / not-configured state ────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_project_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No project selected"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_project_empty_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Long-press widget to reconfigure"
                android:textColor="@color/widget_text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
