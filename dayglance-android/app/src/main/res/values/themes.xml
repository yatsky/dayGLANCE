<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme — inherits from Material3 -->
    <style name="Theme.DayGlance" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary: DayGlance blue -->
        <item name="colorPrimary">#3b82f6</item>
        <item name="colorPrimaryVariant">#2563eb</item>
        <!-- Accent: DayGlance orange -->
        <item name="colorSecondary">#f97316</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Settings activity — with action bar -->
    <style name="Theme.DayGlance.Settings" parent="Theme.DayGlance">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
    </style>

    <!-- Splash screen — shown while WebView loads; transitions to Theme.DayGlance -->
    <style name="Theme.DayGlance.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0f172a</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.DayGlance</item>
    </style>
</resources>
